# =============================================================================
# Coding Bridge MCP - 多 Provider 环境变量示例
# =============================================================================

# 接入模式 / Provider：
#   xfyun-coding     -> 讯飞星辰 MaaS Coding Plan（默认）
#   xfyun-http       -> 星火大模型通用 OpenAI 兼容接口
#   xfyun-websocket  -> 星火大模型原生 WebSocket 接口
#   volcengine-coding -> 火山方舟 Coding Plan 个人版
PROVIDER=xfyun-coding

# ------------------------------------------------------------------------------
# API Key（通用入口，根据 PROVIDER 自动分发到对应厂商）
# ------------------------------------------------------------------------------
API_KEY=your-api-key

# 仍兼容旧变量，当 API_KEY 为空时按以下顺序回退：
#   讯飞: SPARK_API_PASSWORD -> SPARK_API_KEY
#   火山: VOLCENGINE_API_KEY -> ARK_API_KEY

# ------------------------------------------------------------------------------
# 讯飞 xfyun 模式（xfyun-coding / xfyun-http / xfyun-websocket）
# ------------------------------------------------------------------------------
# 仅 WebSocket 模式必填
# SPARK_APP_ID=your-app-id
# SPARK_API_KEY=your-api-key
# SPARK_API_SECRET=your-api-secret

# ------------------------------------------------------------------------------
# 可选配置
# ------------------------------------------------------------------------------
# 默认模型；不同 Provider 有各自的默认值，也可显式覆盖
#   xfyun-coding    默认: astron-code-latest
#   xfyun-http      默认: 4.0Ultra
#   volcengine-coding 默认: ark-code-latest
# SPARK_DEFAULT_MODEL=astron-code-latest
# VOLCENGINE_MODEL=ark-code-latest

# 请求超时（秒）
MCP_TIMEOUT_SECONDS=120

# 单会话最大消息条数
MCP_MAX_MESSAGES=40

# 上下文历史字符上限与单次输出 tokens 不再给出固定值，
# 由当前 PROVIDER 的默认值决定（详见 README §5「Provider 默认值一览」）。
# 如确需覆盖，按以下格式显式声明：
# MCP_MAX_CONTEXT_CHARS=96000
# MCP_MAX_TOKENS=8192

# HTTP/WS 端点覆盖（通常无需修改）
# SPARK_API_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2/chat/completions
# SPARK_WS_URL=wss://spark-api.xf-yun.com/v4.0/chat
# VOLCENGINE_API_URL=https://ark.cn-beijing.volces.com/api/coding/v3/chat/completions
