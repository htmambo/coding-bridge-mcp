# =============================================================================
# Coding Bridge MCP - 多 Provider 环境变量示例
# =============================================================================

# 接入模式 / Provider：
#   xfyun-coding     -> 讯飞星辰 MaaS Coding Plan（默认）
#   volcengine-coding -> 火山方舟 Coding Plan 个人版
#   qianfan-coding   -> 百度智能云千帆 Coding Plan（OpenAI 兼容）
#   opencode-go      -> OpenCode Go 订阅 OpenAI 兼容子集（experimental；见下注）
#   sensenova        -> 商汤日日新 SenseNova Token Plan（OpenAI 兼容）
#   deepseek         -> DeepSeek 官方 API（OpenAI 兼容）
PROVIDER=xfyun-coding

# ------------------------------------------------------------------------------
# API Key（通用入口，根据 PROVIDER 自动分发到对应厂商）
# ------------------------------------------------------------------------------
API_KEY=your-api-key

# 仍兼容旧变量，当 API_KEY 为空时按以下顺序回退：
#   讯飞: SPARK_API_PASSWORD -> SPARK_API_KEY
#   火山: VOLCENGINE_API_KEY -> ARK_API_KEY
#   千帆: QIANFAN_API_KEY
#   OpenCode Go: OPENCODE_API_KEY
#   商汤 SenseNova: SENSENOVA_API_KEY
#   DeepSeek: DEEPSEEK_API_KEY

# ------------------------------------------------------------------------------
# 讯飞 xfyun-coding 模式（API Key 统一使用 API_KEY）
# ------------------------------------------------------------------------------
# 以下两个变量已废弃（Legacy），仅用于向后兼容，新部署请勿使用：
# SPARK_API_PASSWORD=your-api-key
# SPARK_API_KEY=your-api-key

# ------------------------------------------------------------------------------
# 可选配置
# ------------------------------------------------------------------------------
# 默认模型；不同 Provider 有各自的默认值，也可显式覆盖
#   xfyun-coding    默认: astron-code-latest
#   volcengine-coding 默认: ark-code-latest
#   qianfan-coding  默认: qianfan-code-latest
#   opencode-go     默认: glm-5.2
#   sensenova       默认: deepseek-v4-flash（可选 sensenova-6.7-flash-lite；⚠️ 配额极低）
#   deepseek        默认: deepseek-v4-pro（可选 deepseek-v4-flash）
# SPARK_DEFAULT_MODEL=astron-code-latest
# VOLCENGINE_MODEL=ark-code-latest
# QIANFAN_MODEL=qianfan-code-latest
# OPENCODE_MODEL=glm-5.2
# SENSENOVA_MODEL=deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek-v4-pro

# OpenCode Go（experimental）：
# - 端点 https://opencode.ai/zen/go/v1/chat/completions，仅覆盖 OpenAI 兼容子集
#   （GLM / Kimi / DeepSeek / MiMo）；MiniMax / Qwen 走 Anthropic 协议，本 Provider 暂不支持
# - 认证头 Authorization: Bearer 为按 OpenAI 兼容惯例的推断，官方文档未明确；
#   首次使用前建议用 curl 实测确认，若 401/403 需排查是否要求 x-api-key 等其他头
# - 额度为美元配额制（5h/$12、周/$30、月/$60），与讯飞/火山的请求次数限制不同
# - max_context_chars=96000 / max_tokens=8192 为保守估计，可由
#   MCP_MAX_CONTEXT_CHARS / MCP_MAX_TOKENS 显式覆盖

# 商汤日日新 SenseNova（Token Plan，公测，⚠️ 配额极低）：
# - 端点 https://token.sensenova.cn/v1/chat/completions，标准 OpenAI 兼容，
#   认证头 Authorization: Bearer sk-...（普通 API Key，非 JWT 签名）
# - ⚠️ Token Plan 配额极低，tpm 限流易触发，连续调用需间隔约 1 分钟
# - 对话模型：deepseek-v4-flash（默认，1M 上下文，思考模式，审查质量较高）、
#   sensenova-6.7-flash-lite（256K 上下文，更快更省 token，配额吃紧时换用）；
#   可用 SENSENOVA_MODEL 切换
# - 注意：sensenova-u1-fast 是图像生成接口（/v1/images/generations），不能作对话模型
# - max_context_chars=96000 / max_tokens=8192 为保守估计，可由
#   MCP_MAX_CONTEXT_CHARS / MCP_MAX_TOKENS 显式覆盖

# DeepSeek 官方 API（OpenAI 兼容）：
# - 端点 https://api.deepseek.com/chat/completions，标准 OpenAI 兼容，
#   认证头 Authorization: Bearer sk-...
# - 对话模型：deepseek-v4-pro（默认，思考模式，审查质量更高）、
#   deepseek-v4-flash（更快更省 token）；可用 DEEPSEEK_MODEL 切换
#   （旧名 deepseek-chat / deepseek-reasoner 将于 2026-07-24 废弃，分别对应
#    deepseek-v4-flash 的非思考 / 思考模式）
# - deepseek-v4-pro 思考模式响应含 reasoning_content，客户端只取最终 content，
#   reasoning_content 被忽略（符合审查工具预期）
# - max_context_chars=96000 / max_tokens=8192 为保守估计，可由
#   MCP_MAX_CONTEXT_CHARS / MCP_MAX_TOKENS 显式覆盖

# 结构化日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# 请求超时（秒），默认 300：上游 LLM 高峰期实测 120 秒易被打断
MCP_TIMEOUT_SECONDS=300

# 单会话最大消息条数
MCP_MAX_MESSAGES=40

# 上下文历史字符上限与单次输出 tokens 不再给出固定值，
# 由当前 PROVIDER 的默认值决定（详见 README §5「Provider 默认值一览」）。
# 如确需覆盖，按以下格式显式声明：
# MCP_MAX_CONTEXT_CHARS=96000
# MCP_MAX_TOKENS=8192

# HTTP 端点覆盖（通常无需修改）
# SPARK_API_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2/chat/completions
# VOLCENGINE_API_URL=https://ark.cn-beijing.volces.com/api/coding/v3/chat/completions
# QIANFAN_API_URL=https://qianfan.baidubce.com/v2/coding/chat/completions
# OPENCODE_API_URL=https://opencode.ai/zen/go/v1/chat/completions
# SENSENOVA_API_URL=https://token.sensenova.cn/v1/chat/completions
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# ------------------------------------------------------------------------------
# 代理（PROXY）
# ------------------------------------------------------------------------------
# 默认: false — 直连厂商 API，忽略环境变量中的 HTTP_PROXY/HTTPS_PROXY/ALL_PROXY。
# 推荐在 MCP 启动配置 (settings.json -> env) 中显式声明，避免被宿主 shell 的
# 代理设置意外劫持业务流量。
#
# 取值:
#   false  (默认)  强制直连；环境变量代理被忽略 (httpx trust_env=False)
#   true / env     启用环境变量代理 (httpx trust_env=True)
#   yes / on / 1   同 true
#   no / off / 0   同 false
#   custom         自定义代理 (HTTP 与 HTTPS 必须同时配置)
#
# 示例 1 — 直连（默认即此行为）:
# PROXY=false
#
# 示例 2 — 使用 shell 中的代理环境变量:
# PROXY=env
#
# 示例 3 — 自定义代理 (HTTP + HTTPS 必填同填，user/password 可选):
# PROXY=custom
# HTTP_PROXY_HOST=proxy.internal
# HTTP_PROXY_PORT=8080
# HTTPS_PROXY_HOST=proxy.internal
# HTTPS_PROXY_PORT=8443
# # 可选认证 (USER 与 PASSWORD 必须成对):
# # HTTP_PROXY_USER=alice
# # HTTP_PROXY_PASSWORD=s3cret

